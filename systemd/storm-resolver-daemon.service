[Unit]
Description=STORM Resolver Background Daemon
After=network-online.target storm-resolver-scanner.service
Wants=network-online.target storm-resolver-scanner.service

[Service]
Type=simple
WorkingDirectory=/opt/nexora-storm
ExecStart=/opt/nexora-storm/.venv/bin/python /opt/nexora-storm/storm_resolver_daemon.py --resolvers-file /opt/nexora-storm/data/resolvers.txt --scanner-json /opt/nexora-storm/state/resolvers_scan.json --scanner-min-pass-rate 0.55 --scanner-max-latency-ms 900 --scanner-min-score 0 --scanner-max-stale-sec 900 --scanner-pools active,standby --active-out /opt/nexora-storm/state/resolvers_active.txt --healthy-out /opt/nexora-storm/state/resolvers_healthy.txt --state-json /opt/nexora-storm/state/resolver_daemon_state.json --zone t1.phonexpress.ir --timeout 1.5 --max-probe 300 --concurrency 60 --probe-mode random --sticky-keep 4 --take 8 --min-healthy 1 --min-active-floor 4 --interval 60 --restart-on-change --restart-cooldown 600
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
